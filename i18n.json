  "risk.strategy": {
    "zh": "应对策略",
    "en": "Response Strategy"
  },
  "risk.strategy_text": {
    "zh": "黄色预警：减仓20-30%，收紧止损。红色预警：仓位降至30%以下，可用期权对冲。始终对照你的持仓集中度来评估。",
    "en": "Yellow: Reduce 20-30%, tighten stops. Red: Reduce to <30%, hedge with options. Always cross-check portfolio concentration."
  },
  "method.title": {
    "zh": "投资方法论",
    "en": "Investment Framework"
  },
  "method.rule_title": {
    "zh": "科技产业传导的黄金规律",
    "en": "The Golden Rule of Tech Cycles"
  },
  "method.rule_text": {
    "zh": "上游先搭台，下游后唱戏。当上游产能爬坡、订单能见度清晰时，周期从概念期切换到业绩兑现期。关注维度：供需缺口(最重要) > 订单能见度 > 业绩兑现速度 > 政策支持 > 资金流向。",
    "en": "Upstream builds the stage, downstream sings. When upstream capacity ramps and visibility solidifies, the cycle shifts from concept to earnings. Priority: Supply gap > Order visibility > Earnings delivery > Policy > Fund flow."
  },
  "method.screen_title": {
    "zh": "快速筛选主线的5个角度",
    "en": "5 Angles to Screen Threads"
  },
  "method.screen_1": {
    "zh": "供需缺口：寻找>30%的紧缺",
    "en": "Supply-Demand Gap: Look for >30% shortage"
  },
  "method.screen_2": {
    "zh": "订单能见度：12个月以上在手订单",
    "en": "Order Visibility: 12+ month backlog"
  },
  "method.screen_3": {
    "zh": "业绩兑现：连续季度超预期",
    "en": "Profit Delivery: Consecutive beats"
  },
  "method.screen_4": {
    "zh": "政策顺风：政府/行业支持",
    "en": "Policy Tailwind: Gov/industry support"
  },
  "method.screen_5": {
    "zh": "资金流向：北向+机构持续流入",
    "en": "Fund Flow: Northbound+institutional inflow"
  },
  "method.pitfall_title": {
    "zh": "必须避开的3个误区",
    "en": "3 Pitfalls to Avoid"
  },
  "method.pitfall_1": {
    "zh": "追概念期无业绩的股票",
    "en": "Chasing concept stocks without earnings"
  },
  "method.pitfall_2": {
    "zh": "忽视估值分位——高PE+增速放缓=危险",
    "en": "Ignoring PE percentile - high PE + slowing growth = danger"
  },
  "method.pitfall_3": {
    "zh": "单一主线重仓无对冲",
    "en": "Single thread concentration without hedging"
  },
  "method.position_title": {
    "zh": "仓位管理规则",
    "en": "Position Sizing Rules"
  },
  "method.pos_1": {
    "zh": "概念期：最多10-20%，严格止损",
    "en": "Phase 1 (Concept): Max 10-20%, tight stops"
  },
  "method.pos_2": {
    "zh": "业绩爆发期：核心仓位40-60%，移动止损",
    "en": "Phase 2 (Growth): Core 40-60%, trailing stops"
  },
  "method.pos_3": {
    "zh": "分化期：降至20-30%，逐步止盈",
    "en": "Phase 3 (Split): Reduce to 20-30%, take profits"
  },
  "method.pos_4": {
    "zh": "成熟期：0-10%，退出或吃股息",
    "en": "Phase 4 (Mature): 0-10%, exit or dividend plays"
  },
